{
  "name": "mockstream-desktop",
  "version": "1.0.25",
  "private": true,
  "description": "Electron desktop client for the Mock Stream exam platform (Windows + macOS).",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "pretest:e2e": "electron-vite build",
    "test:e2e": "playwright test",
    "prepack": "npm --prefix ../mockstream-runner run build",
    "pack": "electron-vite build && electron-builder --dir",
    "predist": "npm --prefix ../mockstream-runner run build",
    "dist": "electron-vite build && electron-builder",
    "release": "npm run dist && node scripts/upload-release.mjs",
    "publish:feed": "node scripts/upload-release.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
