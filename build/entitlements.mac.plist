<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Electron needs JIT + writable/executable memory for the V8 engine. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow loading the bundled native modules / framework libraries. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- The runner fetches mock content + audio over the network. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Microphone — the Speaking exam records spoken answers. Without this the
         hardened runtime blocks audio input on macOS (mic dead, no waveform). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
  </dict>
</plist>
